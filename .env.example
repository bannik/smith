# The Audacity Timeline — Environment Variables
# Copy this to ~/.openclaw/.env and fill in your keys

# Claude API (for content generation)
ANTHROPIC_API_KEY=sk-ant-...

# X/Twitter API (Basic tier, $200/month)
TWITTER_API_KEY=your_consumer_key_here
TWITTER_API_SECRET=your_consumer_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Telegram Bot (for daily reports)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
